@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Components.Web

<PageTitle>Đăng nhập - Publisher</PageTitle>

<div class="d-flex align-items-center justify-content-center min-vh-100 bg-light">
    <div class="card shadow-sm" style="width: 22rem;">
        <div class="card-body p-4">
            <h1 class="h4 text-center mb-1">Multi-Site CMS Publisher</h1>
            <p class="text-muted text-center small mb-4">Đăng nhập để tiếp tục</p>

            @if (HasError)
            {
                <div class="alert alert-danger py-2" role="alert">
                    Tên đăng nhập hoặc mật khẩu không đúng.
                </div>
            }

            <form method="post" action="/auth/login">
                <AntiforgeryToken />
                <input type="hidden" name="returnUrl" value="@ReturnUrl" />

                <div class="mb-3">
                    <label class="form-label" for="username">Tên đăng nhập</label>
                    <input class="form-control" id="username" name="username" autocomplete="username" required autofocus />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="password">Mật khẩu</label>
                    <input class="form-control" id="password" name="password" type="password" autocomplete="current-password" required />
                </div>

                <button class="btn btn-primary w-100" type="submit">Đăng nhập</button>
            </form>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private bool HasError => Error == "1";
}
