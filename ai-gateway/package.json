{
  "name": "ai-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI content gateway wrapping codex CLI with Claude/Gemini fallback",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --target node20 --clean --sourcemap",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@fastify/rate-limit": "^10.2.1",
    "@google/generative-ai": "^0.21.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "p-limit": "^6.1.0",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
