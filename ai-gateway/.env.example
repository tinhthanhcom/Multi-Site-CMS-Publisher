# Copy to .env (gitignored) and fill in real values. NEVER put real keys here.
# --- Gateway ---
PORT=8080
LOG_LEVEL=info
# Shared secret the CMS must send as: Authorization: Bearer <this>
AI_GATEWAY_API_KEY=change-me

# --- Provider order & limits ---
PROVIDER_ORDER=codex,claude,gemini
DEFAULT_MODEL=gpt-5.4
MAX_CONCURRENCY=3
REQUEST_TIMEOUT_MS=120000

# --- Codex CLI (primary) ---
CODEX_BIN=codex
# Force-enable codex with no API key (ChatGPT login). Leave false if using a key.
CODEX_ENABLED=false
# Model for `codex exec -m`. Empty => codex's own default.
CODEX_MODEL=
# Isolated CODEX_HOME so the gateway never touches your personal ~/.codex.
CODEX_HOME=

# --- Local testing only ---
# Deterministic fake provider so you can run end-to-end with no real keys.
# Set true AND put `mock` in PROVIDER_ORDER (e.g. PROVIDER_ORDER=mock). Never use in prod.
MOCK_PROVIDER=false

# --- Provider credentials (set what you use) ---
# Primary: codex CLI uses OPENAI_API_KEY (or CODEX_API_KEY) headless
OPENAI_API_KEY=
CODEX_API_KEY=
# Fallback 1
ANTHROPIC_API_KEY=
# Fallback 2
GEMINI_API_KEY=
