# --- Gateway ---
PORT=8080
LOG_LEVEL=info
# Shared secret the CMS must send as: Authorization: Bearer <this>
AI_GATEWAY_API_KEY=change-me

# --- Provider order & limits ---
PROVIDER_ORDER=codex,claude,gemini
DEFAULT_MODEL=gpt-5.4
MAX_CONCURRENCY=3
REQUEST_TIMEOUT_MS=120000
CODEX_BIN=codex

# --- Provider credentials (set what you use) ---
# Primary: codex CLI uses OPENAI_API_KEY (or CODEX_API_KEY) headless
OPENAI_API_KEY=
CODEX_API_KEY=
# Fallback 1
ANTHROPIC_API_KEY=
# Fallback 2
GEMINI_API_KEY=
